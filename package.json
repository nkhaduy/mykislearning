{
  "type": "module",
  "scripts": {
    "start:spa": "node scripts/spa-fallback-server.mjs",
    "build": "node scripts/build-static.mjs",
    "cf:dev": "npm run build && NODE_TLS_REJECT_UNAUTHORIZED=0 npx wrangler dev",
    "cf:deploy": "npm run build && NODE_TLS_REJECT_UNAUTHORIZED=0 npx wrangler deploy"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "impeccable": "github:pbakaus/impeccable",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },
  "allowScripts": {
    "puppeteer@25.1.0": true
  }
}
