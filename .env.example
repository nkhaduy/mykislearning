# Supabase — Public keys (safe to expose in browser)
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# For this project (vanilla JS, no bundler) these map to:
# window.SUPABASE_URL and window.SUPABASE_ANON_KEY
# which are injected via /api/config endpoint (server-side) OR
# you can set them in Vercel Environment Variables and they will
# be available in API routes only.

# Secret key — SERVER SIDE ONLY, never in browser
# Used by /api/* Vercel serverless functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database direct connection (for migrations via Supabase CLI)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
